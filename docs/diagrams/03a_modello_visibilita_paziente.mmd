    %% Legenda interna:
    %% SS = stesso soggetto / dati propri
    %% ALL = dati leggibili da tutti gli utenti previsti dalla policy
    %% CRUD = Create Read Update Delete, con "_" quando l'azione non e' consentita

    %% --- Entita' con matrice RLS per Paziente ---

    E_Prof["profiles<br>===<br>SS<br>C R U _"]:::entity
    E_Op["operatori<br>===<br>ALL<br>_ R _ _"]:::entity
    E_Paz["pazienti<br>===<br>SS<br>C R _ _"]:::entity
    E_Far["farmaci<br>===<br>SS<br>_ R _ _"]:::entity
    E_FarLog["farmaci_log<br>===<br>SS<br>C R U _"]:::entity
    E_Es["esercizi<br>===<br>SS<br>_ R _ _"]:::entity
