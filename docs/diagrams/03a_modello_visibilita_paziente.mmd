    R_ProfOp{"profilo di<br>-<br>ALL | _ R _ _"}:::relation
    R_ProfPaz{"profilo di<br>-<br>SS<br>| C R _ _"}:::relation
    R_OpPaz{"gestito da<br>-<br>SS<br>| C R _ _"}:::relation

    R_PazFar{"deve assumere<br>-<br>SS<br>| _ R _ _"}:::relation
