    %% --- Entita' con matrice RLS per Operatore ---

    E_Prof["profiles<br>===<br>SS<br>C R U _"]:::entity

    E_Op["operatori<br>===<br>ALL/SS<br>C R U _"]:::entity

    E_Paz["pazienti<br>===<br>SS<br>_ R U _"]:::entity

